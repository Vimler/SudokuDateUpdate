{
    "name": "SudokuDateUpdate",
    "description": "Update date of sudoku webpage",
    "version": "1.0",
    "manifest_version": 3,
    "background": {
        "service_worker": "scripts/background.js"
    },
    "permissions": [
	"bookmarks",
	"tabs",
    	"scripting"
    ],
    "content_scripts": [
    	{
      		"matches": ["<all_urls>"],
      		"js": ["scripts/content.js"]
    	}
  ]
}
